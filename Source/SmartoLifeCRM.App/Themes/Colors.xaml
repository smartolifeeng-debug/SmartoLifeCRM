<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="SmartoOrangeColor">#F47A20</Color>
    <Color x:Key="SmartoOrangeDarkColor">#D8610E</Color>
    <Color x:Key="SmartoOrangeLightColor">#FFF0E7</Color>
    <Color x:Key="SmartoBlackColor">#111111</Color>
    <Color x:Key="SmartoNavigationColor">#171717</Color>
    <Color x:Key="SmartoNavigationHoverColor">#2A2A2A</Color>
    <Color x:Key="SmartoWhiteColor">#FFFFFF</Color>
    <Color x:Key="SmartoPageBackgroundColor">#F6F7F9</Color>
    <Color x:Key="SmartoSurfaceColor">#FFFFFF</Color>
    <Color x:Key="SmartoSoftSurfaceColor">#FAFAFB</Color>
    <Color x:Key="SmartoBorderColor">#E4E7EC</Color>
    <Color x:Key="SmartoMutedTextColor">#667085</Color>
    <Color x:Key="SmartoHeadingTextColor">#101828</Color>
    <Color x:Key="SmartoWarningColor">#D97706</Color>

    <SolidColorBrush x:Key="SmartoOrangeBrush" Color="{StaticResource SmartoOrangeColor}" />
    <SolidColorBrush x:Key="SmartoOrangeDarkBrush" Color="{StaticResource SmartoOrangeDarkColor}" />
    <SolidColorBrush x:Key="SmartoOrangeLightBrush" Color="{StaticResource SmartoOrangeLightColor}" />
    <SolidColorBrush x:Key="SmartoBlackBrush" Color="{StaticResource SmartoBlackColor}" />
    <SolidColorBrush x:Key="SmartoNavigationBrush" Color="{StaticResource SmartoNavigationColor}" />
    <SolidColorBrush x:Key="SmartoNavigationHoverBrush" Color="{StaticResource SmartoNavigationHoverColor}" />
    <SolidColorBrush x:Key="SmartoWhiteBrush" Color="{StaticResource SmartoWhiteColor}" />
    <SolidColorBrush x:Key="SmartoPageBackgroundBrush" Color="{StaticResource SmartoPageBackgroundColor}" />
    <SolidColorBrush x:Key="SmartoSurfaceBrush" Color="{StaticResource SmartoSurfaceColor}" />
    <SolidColorBrush x:Key="SmartoSoftSurfaceBrush" Color="{StaticResource SmartoSoftSurfaceColor}" />
    <SolidColorBrush x:Key="SmartoBorderBrush" Color="{StaticResource SmartoBorderColor}" />
    <SolidColorBrush x:Key="SmartoMutedTextBrush" Color="{StaticResource SmartoMutedTextColor}" />
    <SolidColorBrush x:Key="SmartoHeadingTextBrush" Color="{StaticResource SmartoHeadingTextColor}" />
    <SolidColorBrush x:Key="SmartoWarningBrush" Color="{StaticResource SmartoWarningColor}" />
    <SolidColorBrush x:Key="SmartoTransparentBrush" Color="Transparent" />
</ResourceDictionary>

