<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <CornerRadius x:Key="SmartoRadiusMedium">14</CornerRadius>
    <CornerRadius x:Key="SmartoRadiusLarge">22</CornerRadius>
    <Thickness x:Key="SmartoCardPadding">22</Thickness>

    <DropShadowEffect x:Key="SmartoSoftShadow"
                      BlurRadius="22"
                      ShadowDepth="2"
                      Opacity="0.10"
                      Color="#111111" />

    <Style TargetType="Window">
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Background" Value="{StaticResource SmartoPageBackgroundBrush}" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource SmartoHeadingTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="20" />
    </Style>

    <Style x:Key="PageTitleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource SmartoHeadingTextBrush}" />
    </Style>

    <Style x:Key="SectionTitleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <Style x:Key="MutedText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource SmartoMutedTextBrush}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="IconText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SmartoSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource SmartoBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource SmartoRadiusLarge}" />
        <Setter Property="Padding" Value="{StaticResource SmartoCardPadding}" />
        <Setter Property="Effect" Value="{StaticResource SmartoSoftShadow}" />
        <Setter Property="Margin" Value="0,0,18,18" />
    </Style>

    <Style x:Key="CardCompact" BasedOn="{StaticResource Card}" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource SmartoRadiusMedium}" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Margin" Value="0,0,12,12" />
    </Style>

    <Style x:Key="EmptyStateCard" BasedOn="{StaticResource Card}" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SmartoSoftSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource SmartoBorderBrush}" />
        <Setter Property="Padding" Value="28" />
    </Style>

    <Style x:Key="DialogCard" BasedOn="{StaticResource Card}" TargetType="Border">
        <Setter Property="MaxWidth" Value="560" />
        <Setter Property="Padding" Value="28" />
        <Setter Property="CornerRadius" Value="{StaticResource SmartoRadiusLarge}" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="Background" Value="{StaticResource SmartoSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource SmartoBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource SmartoHeadingTextBrush}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="Background" Value="{StaticResource SmartoSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource SmartoBorderBrush}" />
    </Style>

    <Style TargetType="DatePicker">
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="Padding" Value="10,4" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{StaticResource SmartoHeadingTextBrush}" />
    </Style>

    <Style TargetType="RadioButton">
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{StaticResource SmartoHeadingTextBrush}" />
    </Style>

    <Style x:Key="BaseButton" TargetType="Button">
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="Padding" Value="18,9" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource SmartoRadiusMedium}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Opacity" Value="0.92" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Opacity" Value="0.82" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource SmartoOrangeBrush}" />
                            <Setter TargetName="Root" Property="BorderThickness" Value="2" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryButton" BasedOn="{StaticResource BaseButton}" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource SmartoOrangeBrush}" />
        <Setter Property="Foreground" Value="{StaticResource SmartoWhiteBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource SmartoOrangeDarkBrush}" />
    </Style>

    <Style x:Key="SecondaryButton" BasedOn="{StaticResource BaseButton}" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource SmartoSurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource SmartoHeadingTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource SmartoBorderBrush}" />
    </Style>

    <Style x:Key="IconButton" BasedOn="{StaticResource BaseButton}" TargetType="Button">
        <Setter Property="Width" Value="44" />
        <Setter Property="MinWidth" Value="44" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="{StaticResource SmartoSurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource SmartoHeadingTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource SmartoBorderBrush}" />
    </Style>

    <Style x:Key="NavigationButton" BasedOn="{StaticResource BaseButton}" TargetType="Button">
        <Setter Property="MinHeight" Value="48" />
        <Setter Property="Margin" Value="10,3" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Background" Value="{StaticResource SmartoTransparentBrush}" />
        <Setter Property="Foreground" Value="{StaticResource SmartoWhiteBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource SmartoTransparentBrush}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource SmartoNavigationHoverBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="StatusBadge" TargetType="Border">
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="Background" Value="{StaticResource SmartoOrangeLightBrush}" />
    </Style>

    <Style x:Key="ValidationMessageText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource SmartoWarningBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource SmartoSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource SmartoBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="RowHeight" Value="44" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="AlternatingRowBackground" Value="{StaticResource SmartoSoftSurfaceBrush}" />
    </Style>

    <Style TargetType="TabControl">
        <Setter Property="Background" Value="{StaticResource SmartoSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource SmartoBorderBrush}" />
    </Style>

    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{StaticResource SmartoBlackBrush}" />
        <Setter Property="Foreground" Value="{StaticResource SmartoWhiteBrush}" />
        <Setter Property="Padding" Value="10,6" />
    </Style>

    <DataTemplate x:Key="QuickActionTemplate">
        <Button Style="{StaticResource SecondaryButton}"
                HorizontalContentAlignment="Stretch"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="38" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding IconGlyph}"
                           Style="{StaticResource IconText}"
                           Foreground="{StaticResource SmartoOrangeBrush}" />
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Description}" Style="{StaticResource MutedText}" FontSize="12" />
                </StackPanel>
            </Grid>
        </Button>
    </DataTemplate>

    <DataTemplate x:Key="RecentRecordTemplate">
        <Border BorderBrush="{StaticResource SmartoBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Subtitle}" Style="{StaticResource MutedText}" />
                </StackPanel>
                <Border Grid.Column="1" Style="{StaticResource StatusBadge}" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Status}"
                               Foreground="{StaticResource SmartoOrangeDarkBrush}"
                               FontSize="12"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="TaskTemplate">
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding DueLabel}" Style="{StaticResource MutedText}" />
            </StackPanel>
            <Border Grid.Column="1" Style="{StaticResource StatusBadge}" VerticalAlignment="Center">
                <TextBlock Text="{Binding Status}"
                           Foreground="{StaticResource SmartoOrangeDarkBrush}"
                           FontSize="12"
                           FontWeight="SemiBold" />
            </Border>
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="ChartPlaceholderTemplate">
        <Border Background="{StaticResource SmartoSoftSurfaceBrush}"
                BorderBrush="{StaticResource SmartoBorderBrush}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="16"
                Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="70" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                <Grid Grid.Row="1" Margin="0,12">
                    <Rectangle Height="10"
                               RadiusX="5"
                               RadiusY="5"
                               Fill="{StaticResource SmartoOrangeLightBrush}"
                               VerticalAlignment="Bottom" />
                    <Rectangle Width="120"
                               Height="10"
                               RadiusX="5"
                               RadiusY="5"
                               Fill="{StaticResource SmartoOrangeBrush}"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Bottom" />
                </Grid>
                <StackPanel Grid.Row="2">
                    <TextBlock Text="{Binding ValueLabel}"
                               Foreground="{StaticResource SmartoOrangeDarkBrush}"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Description}" Style="{StaticResource MutedText}" />
                </StackPanel>
            </Grid>
        </Border>
    </DataTemplate>
</ResourceDictionary>

